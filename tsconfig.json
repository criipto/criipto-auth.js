{
  "declaration": true,
  "compilerOptions": {
    "sourceMap": true,
    "lib": ["dom", "dom.iterable", "es7", "es2017.object", "es2018.promise"],
    "target": "es6",
    "outDir": "./dist",
    "noImplicitAny": true,
    "allowJs": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src"]
}
